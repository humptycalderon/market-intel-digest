# Anthropic — required for Claude synthesis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion — optional, for publishing digest as a Notion page
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DIGEST_PAGE_ID=your_notion_parent_page_id_here

# Telegram — optional, for delivering digest via Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
